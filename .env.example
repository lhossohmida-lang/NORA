# Cloudinary — unsigned upload preset (for product images)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# OpenRouter — AI provider (used by AIChatWidget, AdminAIAssistant, generateProductContent)
# Get a key at https://openrouter.ai/keys — model: arcee-ai/trinity-large-thinking:free
VITE_OPENROUTER_API_KEY=

# Optional — comma-separated emails allowed into /admin
# If empty, any authenticated Firebase user can reach the admin panel.
VITE_ADMIN_EMAILS=
