rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated (admin role in this system)
    function isAdmin() {
      return request.auth != null;
    }

    // products:
    // - Read: Accessible to anyone so clients can browse the catalog.
    // - Write: Restricted to authenticated admin users.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // chatMessages:
    // - Create: Anyone can send chat messages to interact with the AI assistant.
    // - Read/Write: Restricted to authenticated admins to view and manage history.
    match /chatMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // orders:
    // - Create: Accessible to anyone so clients can submit orders.
    // - Read/Write: Restricted to authenticated admins to manage and process orders.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // settings:
    // - Read: Accessible to anyone so the AI assistant (client and admin side) can retrieve the OpenRouter key.
    // - Write: Restricted to authenticated admins to manage configurations.
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // deliveryRates:
    // - Read: Accessible to anyone so the storefront can show delivery prices per zone.
    // - Write: Restricted to authenticated admins to manage the rates.
    match /deliveryRates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
